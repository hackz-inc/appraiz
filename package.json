{
  "name": "tset",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "preview": "pnpm run build && wrangler dev --remote",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "biome check",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate:local": "wrangler d1 migrations apply appraiz --local",
    "db:migrate:staging": "wrangler d1 migrations apply appraiz-staging --remote",
    "db:migrate:production": "wrangler d1 migrations apply appraiz-production --remote",
    "db:seed:local": "wrangler d1 execute appraiz --local --file=./drizzle/seed.sql",
    "db:seed:staging": "wrangler d1 execute appraiz-staging --remote --file=./drizzle/seed.sql",
    "db:seed:production": "wrangler d1 execute appraiz-production --remote --file=./drizzle/seed.sql",
    "secret:put": "wrangler secret put JWT_SECRET"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-core": "^1.171.5",
    "@tanstack/router-plugin": "^1.132.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@apple-yagi/oxlint-config": "^0.1.3",
    "@biomejs/biome": "2.4.5",
    "@cloudflare/vite-plugin": "^1.38.0",
    "@cloudflare/workers-types": "^4.20260522.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^28.1.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.0.5",
    "wrangler": "^4.94.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "@parcel/watcher",
      "workerd",
      "better-sqlite3"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
